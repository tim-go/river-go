rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /contribution-photos/{userId}/{contributionId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 6 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Group cover photos. Anyone may upload under their own uid path; the API
    // authorises whether they can attach it to a group (managers only).
    match /group-covers/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 6 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
