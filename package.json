    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
