{
  "name": "river-go",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0 --port ${PORT:-6173}",
    "dev:stop": "node scripts/dev/stop-dev-ports.mjs",
    "env:local:staging": "node scripts/dev/write-local-firebase-env.mjs staging",
    "env:local:prod": "node scripts/dev/write-local-firebase-env.mjs prod",
    "build": "tsc -b && vite build",
    "pwa:assets": "node scripts/build/generate-pwa-assets.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "api:build": "npm --prefix api run build",
    "api:dev": "node scripts/dev/start-api-dev.mjs local",
    "api:dev:staging": "node scripts/dev/start-api-dev.mjs staging",
    "api:start": "npm --prefix api run start",
    "api:migrate": "npm --prefix api run db:migrate",
    "api:seed:map-pois": "npm --prefix api run seed:map-pois",
    "api:ingest:observations": "npm --prefix api run ingest:observations",
    "api:backfill:observations": "npm --prefix api run backfill:observations --",
    "api:seed:observations": "npm --prefix api run seed:observations",
    "api:seed:river-geometry": "npm --prefix api run seed:river-geometry",
    "api:seed:amenities": "npm --prefix api run seed:amenities",
    "api:backfill:w3w": "node scripts/dev/run-api-runtime-command.mjs local npm --prefix api run backfill:w3w --",
    "api:import:osm-waterways": "RIVER_GO_DATABASE_URL_KEY=adminUrl node scripts/dev/run-api-runtime-command.mjs local npm --prefix api run import:osm-waterways --",
    "api:import:osm-amenities": "RIVER_GO_DATABASE_URL_KEY=adminUrl node scripts/dev/run-api-runtime-command.mjs local npm --prefix api run import:osm-amenities --",
    "data:seed:canonical-river-pilots": "RIVER_GO_DATABASE_URL_KEY=adminUrl node scripts/dev/run-api-runtime-command.mjs local npm --prefix api run seed:canonical-river-pilots --",
    "data:spike:canonical-rivers": "npm --prefix api run spike:canonical-rivers --",
    "osm:download-extract": "scripts/data/download-osm-extract.sh",
    "osm:prepare-waterways": "scripts/data/prepare-osm-waterways.sh",
    "osm:prepare-amenities": "scripts/data/prepare-osm-amenities.sh",
    "import:os-open-rivers": "scripts/data/import-os-open-rivers.sh",
    "build:river-geometry": "node api/scripts/build-river-geometry.mjs",
    "seed:rivers": "npm run import:os-open-rivers && npm run build:river-geometry",
    "platform:import:osm-waterways:staging": "npm --prefix platform run import:osm-waterways:staging --",
    "platform:import:osm-waterways:prod": "npm --prefix platform run import:osm-waterways:prod --",
    "platform:import:osm-amenities:staging": "npm --prefix platform run import:osm-amenities:staging --",
    "platform:import:osm-amenities:prod": "npm --prefix platform run import:osm-amenities:prod --",
    "api:sync:smoke": "npm --prefix api run sync:smoke",
    "platform:check": "npm --prefix platform run check",
    "platform:plan:staging": "npm --prefix platform run plan:staging",
    "platform:plan:prod": "npm --prefix platform run plan:prod",
    "platform:setup:staging": "npm --prefix platform run setup:staging --",
    "platform:setup:prod": "npm --prefix platform run setup:prod --",
    "platform:setup:cicd:staging": "npm --prefix platform run setup:cicd:staging --",
    "platform:setup:cicd:prod": "npm --prefix platform run setup:cicd:prod --",
    "platform:setup:scheduler:staging": "npm --prefix platform run setup:scheduler:staging --",
    "platform:setup:scheduler:prod": "npm --prefix platform run setup:scheduler:prod --",
    "platform:setup:password-policy:staging": "npm --prefix platform run setup:password-policy:staging --",
    "platform:setup:password-policy:prod": "npm --prefix platform run setup:password-policy:prod --",
    "platform:sync-config:staging": "npm --prefix platform run sync-config:staging --",
    "platform:sync-config:prod": "npm --prefix platform run sync-config:prod --",
    "platform:setup-auth-domains:staging": "npm --prefix platform run setup-auth-domains:staging --",
    "platform:setup-auth-domains:prod": "npm --prefix platform run setup-auth-domains:prod --",
    "platform:health:staging": "npm --prefix platform run health:staging",
    "platform:health:prod": "npm --prefix platform run health:prod",
    "platform:auth:staging": "npm --prefix platform run auth:staging",
    "platform:auth:inline:staging": "npm --prefix platform run auth:inline:staging",
    "platform:auth:prod": "npm --prefix platform run auth:prod",
    "platform:auth:inline:prod": "npm --prefix platform run auth:inline:prod",
    "platform:migrate:staging": "npm --prefix platform run migrate:staging --",
    "platform:migrate:prod": "npm --prefix platform run migrate:prod --",
    "platform:backfill:observations:staging": "npm --prefix platform run backfill:observations:staging --",
    "platform:backfill:observations:historic:staging": "npm --prefix platform run backfill:observations:historic:staging --",
    "platform:backfill:observations:prod": "npm --prefix platform run backfill:observations:prod --",
    "platform:seed:observations:staging": "npm --prefix platform run seed:observations:staging --",
    "platform:seed:observations:prod": "npm --prefix platform run seed:observations:prod --",
    "platform:seed:river-geometry:staging": "npm --prefix platform run seed:river-geometry:staging --",
    "platform:seed:river-geometry:prod": "npm --prefix platform run seed:river-geometry:prod --",
    "platform:seed:amenities:staging": "npm --prefix platform run seed:amenities:staging --",
    "platform:seed:amenities:prod": "npm --prefix platform run seed:amenities:prod --",
    "platform:backfill:w3w:staging": "npm --prefix platform run backfill:w3w:staging --",
    "platform:backfill:w3w:prod": "npm --prefix platform run backfill:w3w:prod --",
    "platform:deploy-api:staging": "npm --prefix platform run deploy-api:staging --",
    "platform:deploy-api:prod": "npm --prefix platform run deploy-api:prod --",
    "platform:deploy-web-preview:staging": "npm --prefix platform run deploy-web-preview:staging --",
    "platform:deploy-web-preview:prod": "npm --prefix platform run deploy-web-preview:prod --",
    "platform:deploy-web:staging": "npm --prefix platform run deploy-web:staging --",
    "platform:deploy-web:prod": "npm --prefix platform run deploy-web:prod --",
    "db:local:up": "npm --prefix platform run db:local:up",
    "db:local:down": "npm --prefix platform run db:local:down",
    "db:local:logs": "npm --prefix platform run db:local:logs",
    "db:local:check": "npm --prefix platform run db:local:check",
    "db:local:psql": "npm --prefix platform run db:local:psql"
  },
  "dependencies": {
    "@fontsource/sora": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@zxcvbn-ts/core": "^4.1.2",
    "@zxcvbn-ts/language-common": "^4.1.2",
    "firebase": "^12.13.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.561.0",
    "playwright-core": "^1.60.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "sharp": "^0.35.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
