{
  "name": "river-go-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node scripts/check-config.mjs",
    "plan:staging": "node scripts/print-plan.mjs staging",
    "plan:prod": "node scripts/print-plan.mjs prod",
    "setup:staging": "scripts/infra/setup.sh staging",
    "setup:prod": "scripts/infra/setup.sh prod",
    "health:staging": "scripts/infra/check-health.sh staging",
    "health:prod": "scripts/infra/check-health.sh prod",
    "auth:staging": "node scripts/check-auth-config.mjs staging",
    "auth:inline:staging": "node scripts/check-auth-config.mjs staging --inline",
    "auth:prod": "node scripts/check-auth-config.mjs prod",
    "auth:inline:prod": "node scripts/check-auth-config.mjs prod --inline",
    "migrate:staging": "scripts/infra/migrate-api-db.sh staging",
    "migrate:prod": "scripts/infra/migrate-api-db.sh prod",
    "backfill:observations:staging": "scripts/infra/backfill-observations.sh staging",
    "backfill:observations:prod": "scripts/infra/backfill-observations.sh prod",
    "backfill:w3w:staging": "scripts/infra/backfill-what3words.sh staging",
    "backfill:w3w:prod": "scripts/infra/backfill-what3words.sh prod",
    "deploy-api:staging": "scripts/infra/deploy-api.sh staging",
    "deploy-api:prod": "scripts/infra/deploy-api.sh prod",
    "deploy-web-preview:staging": "scripts/infra/deploy-web.sh staging --preview",
    "deploy-web-preview:prod": "scripts/infra/deploy-web.sh prod --preview",
    "deploy-web:staging": "scripts/infra/deploy-web.sh staging --live",
    "deploy-web:prod": "scripts/infra/deploy-web.sh prod --live",
    "db:local:up": "docker compose -f docker/docker-compose.yml up -d",
    "db:local:down": "docker compose -f docker/docker-compose.yml down",
    "db:local:logs": "docker compose -f docker/docker-compose.yml logs -f db",
    "db:local:check": "psql \"postgresql://river_go_admin:river_go@127.0.0.1:5435/river_go\" -c \"SELECT PostGIS_Version();\"",
    "db:local:psql": "psql \"postgresql://river_go_admin:river_go@127.0.0.1:5435/river_go\""
  }
}
